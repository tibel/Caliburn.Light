<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:Caliburn.Light.Gallery.Avalonia.PageNavigation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Caliburn.Light.Gallery.Avalonia.PageNavigation.Child2View"
             x:DataType="local:Child2ViewModel"
             Header="Child 2"
             Background="LightBlue">
    <StackPanel VerticalAlignment="Bottom">
        <Button Content="Navigate Child 1"
                Command="{Binding NavigateCommand, Mode=OneTime}" />
    </StackPanel>
</ContentPage>
